{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",

    "allowJs": true,
    "checkJs": false,

    "strict": false,

    "esModuleInterop": true,
    "skipLibCheck": true,
    // "noEmit": true,

    "allowSyntheticDefaultImports": true,
    
    "outDir": "./dist",
    "rootDir": "./src",
  },
  "include": ["src"]
}